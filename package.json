{
  "name": "@webuplink/mcp",
  "version": "0.1.0",
  "description": "MCP server for WebUplink — give any AI agent the ability to browse and interact with the web.",
  "license": "MIT",
  "keywords": ["webuplink", "mcp", "ai-agent", "browser", "model-context-protocol"],
  "type": "module",
  "bin": {
    "webuplink-mcp": "./dist/index.js",
    "webuplink-mcp-http": "./dist/http.js"
  },
  "exports": {
    ".": {
      "import": "./dist/tools.js",
      "types": "./dist/tools.d.ts"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "https://github.com/webuplink-dev/webuplink-mcp.git"
  },
  "homepage": "https://webuplink.ai",
  "bugs": {
    "url": "https://github.com/webuplink-dev/webuplink-mcp/issues"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "webuplink": "^0.1.0",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "~5.8.2",
    "vitest": "^3.2.6"
  }
}
