{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.webuplink/mcp",
  "title": "WebUplink",
  "description": "Give any MCP client the ability to browse and interact with the web via WebUplink.",
  "repository": {
    "url": "https://github.com/webuplink-dev/webuplink-mcp",
    "source": "github"
  },
  "version": "0.1.1",
  "websiteUrl": "https://webuplink.ai",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@webuplink/mcp",
      "version": "0.1.1",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "WEBUPLINK_API_KEY",
          "description": "Your WebUplink API key",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
